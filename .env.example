# Environment Variables Example
# Copy this file to .env and fill in your values

# MongoDB Connection (required for production)
# Get your connection string from MongoDB Atlas or use local MongoDB
MONGO_URI=mongodb://localhost:27017/freesewaa

# Server Configuration
PORT=3000
NODE_ENV=development

# Session Secret (change this!)
SESSION_SECRET=your-super-secret-session-key-change-this

# Admin Credentials (optional - defaults exist)
# ADMIN_EMAIL=admin@freesewaa.local
# ADMIN_PASSWORD=admin12345

# Application URL (for production)
APP_URL=http://localhost:3000